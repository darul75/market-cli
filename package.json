{
  "name": "market-cli",
  "version": "0.2.1",
  "description": "Real-time stock portfolio tracking CLI",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir=dist --target=node",
    "start": "bun run dist/main.js",
    "test": "bun test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "rxjs": "^7.8.1",
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
