{
  "name": "market-cli",
  "version": "0.4.1",
  "description": "Real-time stock portfolio tracking CLI",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "build": "bun build src/main.ts --outdir=dist --target=node",
    "start": "bun run dist/main.js",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "format": "biome format --write ./src",
    "format:check": "biome format check ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "rxjs": "^7.8.1",
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
